# Data layer mode: "local" (localStorage, solo, Phases 1-2) or "cloud" (Supabase, Phase 3+)
VITE_DATA_MODE=local

# Phase 3+ (Supabase)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Phase 3+ (Web Push, VAPID public key is client-exposed; private key stays server-side, never VITE_-prefixed)
VITE_VAPID_PUBLIC_KEY=

# Phase 4 (AI input — keys stay server-side, never VITE_-prefixed)
