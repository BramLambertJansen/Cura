# Data layer mode: "local" (localStorage, solo, Phases 1-2) or "cloud" (Supabase, Phase 3+)
VITE_DATA_MODE=local

# Phase 3+ (Supabase)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Web Push (real push notifications). The PUBLIC key is client-exposed here (used
# as pushManager.subscribe applicationServerKey, urlsafe-base64). Generate a
# keypair with @negrel/webpush (see supabase/functions/_shared/webpush.ts).
VITE_VAPID_PUBLIC_KEY=
#
# The following are SERVER-SIDE secrets — NOT in this client env file. Set them
# on the Supabase project so the send-reminders edge function + cron can run:
#   supabase secrets set VAPID_KEYS='<exported JWK pair JSON>'
#   supabase secrets set VAPID_CONTACT='mailto:feedback@cura.app'   # optional
#   supabase secrets set CRON_SECRET='<random string>'              # same value as Vault secret cura_cron_secret
# (SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY are injected into edge functions automatically.)
#
# The reminder-cron migration also reads Vault secret cura_functions_base_url,
# e.g. https://<your-project-ref>.supabase.co, to avoid hardcoding one project.

# Phase 4 (AI input — keys stay server-side, never VITE_-prefixed)
