{
  "pkg": "cura",
  "globalName": "Cura",
  "shape": "package",
  "srcDir": "src/app/components",
  "tsconfig": ".design-sync/tsconfig.ds.json",
  "buildCmd": "pnpm build",
  "cssEntry": ".design-sync/ds-compiled.css",
  "readmeHeader": ".design-sync/conventions.md",
  "extraEntries": ["react-router"],
  "overrides": {
    "Sheet": { "cardMode": "single", "viewport": "400x640" },
    "Popover": { "cardMode": "single", "viewport": "440x420" },
    "FullScreenError": { "cardMode": "single", "viewport": "390x680" },
    "FullScreenSkeleton": { "cardMode": "single", "viewport": "390x680" },
    "TimerDisplay": { "cardMode": "single", "viewport": "340x340" },
    "PullToRefreshIndicator": { "cardMode": "single", "viewport": "390x280" },
    "TaakRij": { "cardMode": "column" },
    "TijdlijnTaakRij": { "cardMode": "column" },
    "SuggestieRij": { "cardMode": "column" },
    "BoodschapRij": { "cardMode": "column" },
    "ActiviteitReacties": { "cardMode": "column" },
    "RoutineKaart": { "cardMode": "column" },
    "KamerKaart": { "cardMode": "column" },
    "KamerKunstKiezer": { "cardMode": "column" },
    "Card": { "cardMode": "column" },
    "GroupCard": { "cardMode": "column" },
    "InstRij": { "cardMode": "column" },
    "Leeg": { "cardMode": "column" },
    "PageHeader": { "cardMode": "column" },
    "HintBanner": { "cardMode": "column" },
    "FieldShell": { "cardMode": "column" },
    "RoomHero": { "cardMode": "column" },
    "SheetHeader": { "cardMode": "column" },
    "TaakToevoegRij": { "cardMode": "column" },
    "VeldInput": { "cardMode": "column" },
    "VeldTextarea": { "cardMode": "column" },
    "ErrorBoundary": { "cardMode": "single" }
  }
}
